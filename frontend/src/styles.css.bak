  grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
  gap: 5px !important;
  margin-top: 8px;
}
.rewardMetric {
  padding: 5px 6px !important;
}
.rewardMetric span {
  font-size: 8px !important;
  margin-bottom: 2px;
}
