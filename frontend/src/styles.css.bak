/* Daily Check-In Panel */
.checkInPanel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 14px 16px;
  margin-bottom: 16px;
  border-radius: 18px;
  background: transparent !important;
  border: 1px solid rgba(103,255,199,.14);
}

.checkInLeft {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.checkInEyebrow {
  color: #00ffa3;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.checkInStatus {
  color: #f2fff7;
  font-size: 14px;
  font-weight: 600;
}

.checkInStatus strong {
  color: #a7ffbf;
  font-size: 18px;
  font-variant-numeric: tabular-nums;
}

.checkInLast {
  color: rgba(230,255,239,.50);
  font-size: 11px;
}

.checkInSuccess {
  color: #a7ffbf;
  font-size: 12px;
  font-weight: 700;
}

.checkInError {
  color: #fca5a5;
  font-size: 11px;
}

.checkInBtn {
  min-width: 100px;
  min-height: 40px;
  padding: 0 16px;
  border-radius: 14px;
  font-size: 13px;
  font-weight: 800;
  background: transparent !important;
  color: #032215;
  white-space: nowrap;
  flex-shrink: 0;
}

.checkInBtn:disabled {
  opacity: 0.42;
  cursor: not-allowed;
}

@media (max-width: 760px) {
  .checkInPanel {
    flex-direction: column;
    align-items: flex-start;
  }
  .checkInBtn {
    width: 100%;
  }
}

/* Leaderboard */
.leaderboardPanel {
  margin-top: 20px;
  padding: 20px;
  border-radius: 20px;
  background: transparent !important;
  border: 1px solid rgba(103,255,199,.11);
}

.leaderboardList {
  margin-top: 12px;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid rgba(103,255,199,.10);
}

.leaderboardHeader {
  display: grid;
  grid-template-columns: 40px 1fr 80px 80px 80px 80px;
  padding: 10px 14px;
  background: rgba(99,255,199,.06);
  color: rgba(230,255,239,.50);
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
}

.leaderboardRow {
  display: grid;
  grid-template-columns: 40px 1fr 80px 80px 80px 80px;
  padding: 12px 14px;
  border-top: 1px solid rgba(103,255,199,.07);
  color: #f2fff7;
  font-size: 13px;
  align-items: center;
}

.leaderboardTop {
  background: rgba(99,255,199,.06);
}

.leaderboardRank {
  color: rgba(230,255,239,.50);
  font-weight: 700;
}

.leaderboardTop .leaderboardRank {
  color: #a7ffbf;
}

.leaderboardAddr {
  font-family: monospace;
  font-size: 12px;
  color: rgba(230,255,239,.80);
}

.leaderboardPoints {
  font-weight: 800;
  color: #a7ffbf;
}

.leaderboardEmpty {
  padding: 20px;
  color: rgba(230,255,239,.50);
  font-size: 13px;
  text-align: center;
}

.leaderboardNote {
  margin-top: 12px;
  color: rgba(230,255,239,.40);
  font-size: 11px;
}

@media (max-width: 760px) {
  .leaderboardHeader,
  .leaderboardRow {
    grid-template-columns: 30px 1fr 50px 50px 50px 50px;
    font-size: 11px;
    padding: 10px;
  }
}

/* v0.6.0 — homepage mobile 2 kolom */
@media (max-width: 760px) {
  .landingGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .primaryLanding {
    grid-column: span 2;
  }
  .wideLanding {
    grid-column: span 2;
  }
  .halfLanding {
    grid-column: span 1;
  }
  .landingCard {
    min-height: unset;
    padding: 16px;
  }
  .landingCard h2 {
    font-size: 16px;
  }
  .landingCard p {
    font-size: 12px;
    margin-bottom: 12px;
  }
}

/* Leaderboard Preview Card */
.leaderboardPreviewCard {
  display: flex;
  flex-direction: column;
}

.leaderboardPreviewList {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin: 10px 0 14px;
}

.leaderboardPreviewRow {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 10px;
  border-radius: 10px;
  background: rgba(99,255,199,.06);
  border: 1px solid rgba(103,255,199,.08);
}

.leaderboardPreviewRank {
  color: #a7ffbf;
  font-size: 11px;
  font-weight: 800;
  min-width: 24px;
}

.leaderboardPreviewAddr {
  font-family: monospace;
  font-size: 11px;
  color: rgba(230,255,239,.75);
  flex: 1;
}

.leaderboardPreviewPts {
  font-size: 12px;
  font-weight: 700;
  color: #f2fff7;
}


/* primaryLanding token chips */
.primaryLandingChips {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 14px;
}

.primaryLandingChips span {
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(99,255,199,.10);
  border: 1px solid rgba(99,255,199,.20);
  color: #a7ffbf;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .04em;
}

/* =========================================
   🚀 BLACK-PINK THEME & PERFORMANCE PATCH
   ========================================= */
:root {
  --bg-main: #0a0a0a !important;
  --bg-card: #181818 !important;
  --accent-pink: #ff69b4 !important;
  --text-main: #ffffff !important;
  --text-muted: rgba(255, 255, 255, 0.6) !important;
  --btn-pink: #e91e8c !important;
  --badge-bg: rgba(255, 105, 180, 0.1) !important;
  --font-main: 'Quicksand', sans-serif !important;
}

body, #root, .app-container, * {
  font-family: var(--font-main) !important;
}

body, .app-wrapper, #root {
  background: var(--bg-main) !important;
  color: var(--text-main) !important;
}

/* Override Cards: Hapus efek kaca & glow hijau lama */
.card, .vault-card, .panel, div[class*="Card"] {
  background-color: var(--bg-card) !important;
  border: 1px solid var(--accent-pink) !important;
  border-radius: 16px !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
  background-image: none !important;
}

.text-muted, p, span.sub-text {
  color: var(--text-muted) !important;
}

h1, h2, h3, .title {
  color: var(--text-main) !important;
  font-weight: 700 !important;
  letter-spacing: -0.5px !important;
}

/* Tombol */
button, .btn, .btn-primary {
  background: var(--btn-pink) !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 8px !important;
  font-weight: 600 !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
}

/* Badge/Chips */
.badge, .status-chip, .tag {
  background-color: var(--badge-bg) !important;
  color: var(--accent-pink) !important;
  border: 1px solid var(--accent-pink) !important;
  border-radius: 20px !important;
  backdrop-filter: none !important;
}

/* =========================================
   ☢️ EXTREME OVERRIDE: BLACK & BLUR PATCH ☢️
   ========================================= */

/* 1. BANTAI GRADIENT HIJAU UTAMA */
html, body, #root, .App, .app, .app-wrapper, .app-container, main {
  background: #0a0a0a !important; /* Paksa hitam murni */
  background-color: #0a0a0a !important;
  background-image: none !important; /* Ini yang bikin hijau nggak mau ilang */
}

/* Matikan elemen bayangan (pseudo) yang sering dipakai buat gradient background */
body::before, body::after, #root::before, #root::after, .app-wrapper::before {
  display: none !important;
  background: none !important;
  background-image: none !important;
}

/* 2. BERSIHKAN SISA HIJAU DI DALAM CARD */
.card, .vault-card, div[class*="Card" i], .panel {
  background: #181818 !important; /* Paksa abu-abu sangat gelap */
  background-color: #181818 !important;
  background-image: none !important;
}

/* 3. DRAWER OVERLAY - HITAM TRANSPARAN + BLUR ELEGANT */
/* Menargetkan semua kemungkinan class name overlay di React/UI Library */
[class*="overlay" i], [class*="Overlay" i],
[class*="backdrop" i], [class*="Backdrop" i],
.drawer-bg, .modal-bg {
  background: rgba(0, 0, 0, 0.65) !important; /* Hitam dengan opacity 65% */
  background-color: rgba(0, 0, 0, 0.65) !important;
  background-image: none !important;
  backdrop-filter: none !important; /* Efek kaca burem sesuai request */
  -webkit-backdrop-filter: none !important;
}

/* =========================================
   ☢️ THE NUCLEAR OPTION: MATIKAN SEMUA GRADIENT ☢️
   ========================================= */

/* Hajar semua div pembungkus yang langsung berada di bawah body atau #root */
body > div, 
#root > div, 
#root > div > div, 
main, 
section, 
[class*="bg-gradient"], 
[class*="from-green"],
[class*="to-green"] {
  background-image: none !important;
  background-color: transparent !important;
}

/* Kunci mati background di level paling dasar */
html, body, #root {
  background: #0a0a0a !important;
  background-color: #0a0a0a !important;
  background-image: none !important;
}

/* Pastikan card tetap abu-abu gelap, bukan hitam tembus pandang */
.card, .vault-card, div[class*="Card" i], .panel {
  background: #181818 !important;
  background-color: #181818 !important;
  background-image: none !important;
}

/* =========================================
   ☠️ SILUMAN GLOW KILLER (FINAL HIT) ☠️
   ========================================= */
.glow, .glowA, .glowB {
  display: none !important;
  opacity: 0 !important;
  background: none !important;
  background-image: none !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
  animation: none !important;
}

/* =========================================
   💅 FINISHING TOUCH: BORDERS, TOPBAR & SPACING
   ========================================= */

/* 1. Pinggiran SEMUA Card Paksa Pink */
.landingCard, 
.heroCard, 
.card, 
.panel, 
.vault-card, 
article[class*="Card" i], 
section.panel, 
.checkInPanel {
  border: 1px solid #ff69b4 !important;
  /* Opsional: Tambahin glow pink super tipis biar nggak terlalu flat, tapi tetap ringan */
  box-shadow: 0 0 10px rgba(255, 105, 180, 0.08) !important; 
}

/* 2. Top Bar Bersih dari Hijau */
.topbar, header.topbar {
  background: #0a0a0a !important;
  background-color: #0a0a0a !important;
  background-image: none !important;
  border-bottom: 1px solid #2a2a2a !important; /* Garis pemisah bawah topbar */
  backdrop-filter: none !important;
}

/* 3. Spasi Saldo ETH & Wallet (RainbowKit Fix) */
.topActions {
  display: flex !important;
  gap: 16px !important; /* Kasih jarak antar tombol di top actions */
  align-items: center !important;
}

/* Target spesifik tombol dompet RainbowKit biar nggak dempet sama saldo */
.topActions [data-testid="rk-account-button"],
.topActions > div > div {
  gap: 10px !important;
  margin-left: 6px !important;
}

/* Tombol hamburger menu biar sejajar manis */
.topActions .iconBtn {
  margin-left: 8px !important;
}

/* =========================================
   🛠️ PATCH SUSULAN: HERO BORDER & RAINBOWKIT
   ========================================= */

/* 1. Paksa Border Pink di Hero & Bunuh Pseudo-element Border Lama */
.hero, .heroCard, .viewHero {
  border: 1px solid #ff69b4 !important;
  border-radius: 16px !important;
}

/* Hapus elemen gaib yang nutupin border di hero card */


/* 2. Fix Spasi RainbowKit (Pemisah Saldo ETH & Dompet) */
/* Memaksa semua div di dalam topActions yang pakai flex untuk punya jarak */
.topActions div {
  gap: 12px !important; 
}

/* Spesifik menargetkan tombol dompet agar menjauh dari saldo */
.topActions button,
.topActions [data-testid="rk-account-button"],
.topActions [data-testid="rk-chain-button"] {
  margin-left: 8px !important;
}

/* Opsional: Kasih border pink tipis juga di tombol wallet biar senada */
.topActions button {
  border: 1px solid rgba(255, 105, 180, 0.4) !important;
}

/* Fix Jarak RainbowKit Super Ekstrem */
[data-testid="rk-account-button"] {
  margin-left: 16px !important; /* Paksa geser ke kanan */
}

/* Beri nafas di container pembungkus saldonya */
.topActions > div > div {
  gap: 12px !important;
}

/* =========================================
   🪓 PEMISAH SALDO DAN DOMPET (RAINBOWKIT FIX)
   ========================================= */

/* Paksa kontainer pembungkus RainbowKit untuk kasih jarak (gap) */
.topActions > div > div, 
.topActions div[style*="display: flex"] {
  gap: 12px !important;
}

/* Kembalikan sudut membulat pada elemen yang sebelumnya nempel, dan beri margin */
.topActions > div > div > div,
.topActions > div > div > button,
[data-testid="rk-account-button"] {
  border-radius: 12px !important; /* Bikin pinggirannya bulat sempurna */
  margin-left: 4px !important;
  margin-right: 4px !important;
}

/* Tambahan: Kasih garis border pink tipis ke saldo biar serasi sama tombol sebelahnya */
.topActions > div > div > div:first-child {
  border: 1px solid rgba(255, 105, 180, 0.4) !important;
}

/* =========================================
   🧲 FIX: TOMBOL PINK & LAYOUT SEIMBANG
   (Tulisan tetap hijau, tidak diubah)
   ========================================= */

/* 1. Warnai Tombol Primary/Secondary jadi Pink */
.primaryBtn, .secondaryBtn, button {
  background: #e91e8c !important; 
  color: #ffffff !important;
  border: none !important;
  border-radius: 8px !important;
  font-weight: 600 !important;
  padding: 10px 18px !important;
  cursor: pointer !important;
}

/* 2. Jurus Flexbox biar Card tidak kopong */
/* Kita buat card jadi column agar bisa diatur ruangnya */
.landingCard, .panel, .vault-card {
  display: flex !important;
  flex-direction: column !important;
  height: 100% !important; /* Paksa card punya tinggi konsisten */
}

/* Biar teks deskripsi mengisi ruang kosong dengan cantik */
.landingCard p {
  flex-grow: 1 !important; 
  margin-bottom: 20px !important;
}

/* Memastikan tombol selalu berada di dasar card agar tidak mengambang */
.landingCard button, 
.landingCard .primaryBtn, 
.landingCard .secondaryBtn {
  margin-top: auto !important; 
  align-self: flex-start !important; 
}

/* =========================================
   🗜️ PATCH: RAPATKAN CARD KOPONG
   ========================================= */

/* 1. Kurangi padding card agar tidak terlalu melompong */
.landingCard, .panel {
  padding: 16px !important;
}

/* 2. Fix layout "Verified Engine" agar tombol dan tabel lebih rapat */
/* Kita targetkan class yang membungkus teks dan button di card tersebut */
.landingCard, .panel {
  gap: 12px !important; /* Kurangi jarak antar elemen di dalam card */
}

/* 3. Paksa tombol "View Contracts" supaya tidak terlalu jauh dari teks */
.landingCard button, .secondaryBtn {
  align-self: flex-start !important; /* Biar nempel kiri, tidak melayang di kanan */
  margin-top: 8px !important;
}

/* 4. Tabel status di bawah dibikin full-width agar tidak terlihat "tenggelam" */
.landingCard table, 
.landingCard div[class*="status"], 
.landingCard > div:last-child {
  width: 100% !important;
}

/* Biar teks di dalam card tidak terlalu lebar/melayang */
.landingCard p {
  max-width: 90% !important;
}

/* =========================================
   🗜️ PATCH: ISI SPACE KOPONG (VISUAL FOOTER)
   ========================================= */

/* 1. Tambahin 'ruang bernapas' biar gak sesak */
.landingCard, .panel {
  padding-bottom: 24px !important; 
  position: relative !important;
}

/* 2. Tambahkan 'Status Bar' dekoratif di bawah card */
.landingCard::after {
  content: "STATUS: SYNCED · PROTOCOL: ACTIVE";
  display: block;
  margin-top: 20px !important;
  padding-top: 10px !important;
  border-top: 1px solid rgba(255, 105, 180, 0.2) !important;
  color: #ff69b4 !important;
  font-size: 9px !important;
  letter-spacing: 1.5px !important;
  text-transform: uppercase !important;
  text-align: center !important;
  opacity: 0.6 !important;
}

/* 3. Khusus buat card yang tombolnya di bawah, rapiin posisinya */
.landingCard {
  justify-content: space-between !important;
}

/* Biar tabel status di card bawah gak kegeser */
.landingCard > div:last-child {
  margin-top: 10px !important;
}

/* =========================================
   🚀 FINAL FIX: PINNING FOOTER & BUTTON
   ========================================= */

/* Paksa semua card punya tinggi minimal biar gak kopong */
.landingCard, .panel {
  min-height: 220px !important; /* Sesuaikan tinggi minimum */
  display: flex !important;
  flex-direction: column !important;
  justify-content: space-between !important;
}

/* Biar teks deskripsi ngambil ruang sisa, biar button kedorong ke bawah */
.landingCard p {
  flex-grow: 1 !important;
  margin-bottom: 16px !important;
}

/* Pastikan footer status ada di paling bawah absolut */
.landingCard::after {
  margin-top: auto !important; /* Dorong ke paling bawah */
  padding-bottom: 0 !important;
}

/* Bikin button-nya lebih rapi posisinya */
.landingCard button {
  margin-top: 10px !important;
  align-self: flex-start !important;
}

/* =========================================
   ✨ PATCH: HEADER PADDING (BIAR GAK MEPET)
   ========================================= */

/* Kasih napas buat judul di dalam semua card */
.sectionHead {
  padding-left: 16px !important;  /* Nambah jarak kiri */
  padding-right: 16px !important; /* Nambah jarak kanan biar simetris */
  padding-top: 8px !important;    /* Nambah jarak atas dikit */
  padding-bottom: 12px !important;
}

/* Pastikan h2 di dalamnya gak punya margin kiri yang aneh */
.sectionHead h2 {
  margin-left: 0 !important;
}

/* =========================================
   ✨ PATCH: LEADERBOARD BORDER FIX
   ========================================= */

/* Menargetkan semua elemen yang terdeteksi sebagai leaderboard */
.leaderboard,
.leaderboardPreviewCard,
[class*="leaderboard" i] {
  border: 1px solid #ff69b4 !important;
  border-radius: 16px !important;
  box-shadow: none !important;
  background-color: #181818 !important; /* Biar senada */
}
