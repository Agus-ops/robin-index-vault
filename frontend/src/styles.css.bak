/* =========================
   OVERRIDE: Hapus garis/aksen pink di Top Ranking / Wallet
   Tempelkan di paling atas src/styles.css
   ========================= */

/* Target umum untuk komponen wallet / leaderboard */
.top-ranking .wallet,
.top-ranking .wallet-card,
.top-ranking .wallet-header,
.leaderboard .wallet,
.leaderboard .wallet-card,
.wallet,
.wallet-card,
.wallet-header,
.wallet-balance,
.wallet-info {
  border: none !important;
  border-left: none !important;
  border-right: none !important;
  border-top: none !important;
  border-bottom: none !important;
  box-shadow: none !important;
  background-image: none !important;
  background-repeat: no-repeat !important;
  background-size: auto !important;
}

/* Hilangkan pseudo-element yang sering dipakai untuk garis dekoratif */
.top-ranking .wallet::before,
.top-ranking .wallet::after,
.wallet::before,
.wallet::after,
.wallet-card::before,
.wallet-card::after,
.leaderboard .wallet::before,
.leaderboard .wallet::after {
  display: none !important;
  content: none !important;
  width: 0 !important;
  height: 0 !important;
}

/* Override inline styles yang menyisipkan warna pink (#ff69b4 / #e91e8c) */
*[style*="#ff69b4"],
*[style*="#e91e8c"],
*[style*="ff69b4"],
*[style*="e91e8c"],
*[style*="pink"] {
  border-color: transparent !important;
  box-shadow: none !important;
  background-image: none !important;
}

/* Jika ada class bernama khusus seperti .wallet-border atau .pink-line */
.wallet-border,
.pink-line,
.line-pink,
.border-pink,
.topline-pink {
  display: none !important;
  border: none !important;
  background: transparent !important;
  box-shadow: none !important;
}

/* Jaga spacing / layout agar tidak bergeser drastis */
.top-ranking, .leaderboard, .wallet-wrapper {
  padding: 0.5rem 0 !important;
}

/* Jika masih terlihat karena outline focus, netralisasi */
.wallet :focus, .wallet-card :focus {
  outline: none !important;
  box-shadow: none !important;
}
@import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap');
:root {
  color-scheme: dark;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: #090d14;
  color: #fff;
}

* { box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  margin: 0;
  min-width: 320px;
  background: transparent !important;
}

button, input { font: inherit; }
button { cursor: pointer; }
button:disabled { cursor: not-allowed; opacity: .55; }
a { color: inherit; text-decoration: none; }

.app { min-height: 100vh; position: relative; overflow-x: hidden; }

.glow {
  position: fixed;
  border-radius: 999px;
  filter: blur(90px);
  pointer-events: none;
  opacity: .35;
}

.glowA { width: 240px; height: 240px; left: -90px; top: 90px; background: #00ffa3; }
.glowB { width: 280px; height: 280px; right: -120px; top: 220px; background: #00e1ff; }

.topbar {
  position: sticky;
  top: 0;
  z-index: 20;
  height: 72px;
  padding: 0 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(9,13,20,.75);
  backdrop-filter: none !important;
  border-bottom: 1px solid rgba(255,255,255,.06);
}

.brand, .topActions, .badges, .assetMain, .assetActions, .sectionHead,
.contractLink, .drawerHead, .chainOk, .chainBad, .rindexBox em {
  display: flex;
  align-items: center;
}

.brand { gap: 12px; }

.brandIcon {
  width: 38px;
  height: 38px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  color: #061018;
  font-weight: 900;
  background: transparent !important;
  box-shadow: none !important;
}

.brand span {
  display: block;
  margin-top: 2px;
  color: #94a3b8;
  font-size: 12px;
}

.topActions { gap: 10px; }

.chainOk, .chainBad {
  gap: 8px;
  padding: 9px 12px;
  border-radius: 999px;
  font-size: 13px;
  color: #cbd5e1;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.07);
}

.chainOk span, .chainBad span {
  width: 8px;
  height: 8px;
  border-radius: 999px;
}

.chainOk span { background: #00ffa3; box-shadow: none !important; }
.chainBad span { background: #ff3b30; box-shadow: none !important; }

.iconBtn {
  border: 0;
  color: #fff;
  width: 42px;
  height: 42px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.08);
}

main {
  width: min(1180px, calc(100% - 28px));
  margin: 0 auto;
  padding: 34px 0 80px;
}

.hero {
  display: grid;
  gap: 18px;
  margin-bottom: 20px;
}

.eyebrow {
  color: #00ffa3;
  font-size: 13px;
  letter-spacing: .08em;
  text-transform: uppercase;
  margin-bottom: 12px;
}

h1, h2, h3, p { margin: 0; }

h1 {
  font-size: clamp(34px, 8vw, 68px);
  line-height: .95;
  letter-spacing: -.06em;
  max-width: 780px;
}

.hero p {
  margin-top: 16px;
  color: #94a3b8;
  max-width: 680px;
  line-height: 1.7;
}

.badges {
  margin-top: 18px;
  flex-wrap: wrap;
  gap: 10px;
}

.badges span, .softPill, .dangerPill {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 11px;
  border-radius: 999px;
  font-size: 13px;
  color: #dbeafe;
  background: rgba(255,255,255,.055);
  border: 1px solid rgba(255,255,255,.075);
}

.heroCard, .panel, .modal, .drawer {
  background: rgba(20,24,33,.62);
  border: 1px solid rgba(255,255,255,.075);
  box-shadow: none !important;
  backdrop-filter: none !important;
}

.heroCard {
  border-radius: 26px;
  padding: 22px;
}

.heroCard span, .sectionHead p, .assetCard span, .bucket span,
.breakdown span, .rindexBox span, .fineprint {
  color: #94a3b8;
}

.heroCard strong {
  display: block;
  font-size: 28px;
  margin: 8px 0;
}

.grid { display: grid; gap: 18px; }
.leftCol, .rightCol { display: grid; gap: 18px; align-content: start; }

.panel {
  border-radius: 26px;
  padding: 20px;
}

.sectionHead {
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 18px;
}

.sectionHead h2 { font-size: 20px; letter-spacing: -.03em; }
.sectionHead p { margin-top: 5px; font-size: 14px; }

.primaryBtn, .assetActions button, .adminGrid button {
  border: 0;
  min-height: 42px;
  padding: 0 14px;
  border-radius: 14px;
  font-weight: 800;
}

.primaryBtn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  color: #061018;
  background: transparent !important;
  box-shadow: none !important;
}

.wide { width: 100%; }

.assetList { display: grid; gap: 12px; }

.assetCard {
  display: grid;
  gap: 14px;
  padding: 16px;
  border-radius: 22px;
  background: rgba(255,255,255,.035);
  border: 1px solid rgba(255,255,255,.06);
}

.assetMain { gap: 12px; }

.tokenMark {
  width: 42px;
  height: 42px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  font-weight: 900;
  color: #00ffa3;
  background: rgba(0,255,163,.08);
  border: 1px solid rgba(0,255,163,.16);
}

.assetMain strong { display: block; }
.assetMain span { display: block; font-size: 13px; margin-top: 2px; }

.assetData { display: grid; gap: 10px; }
.assetData div { display: flex; justify-content: space-between; gap: 10px; }

.assetData strong, .contractLink strong, .bigNumber, .rindexBox strong, .breakdown strong {
  font-family: "JetBrains Mono", "Roboto Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
}

.assetActions { gap: 10px; }

.assetActions button {
  flex: 1;
  color: #fff;
  background: rgba(255,255,255,.065);
  border: 1px solid rgba(255,255,255,.075);
}

.assetActions button:first-child {
  color: #061018;
  background: #00ffa3;
}

.bigNumber {
  font-size: clamp(34px, 10vw, 52px);
  font-weight: 900;
  letter-spacing: -.06em;
  margin-bottom: 18px;
}

.rindexBox {
  padding: 16px;
  border-radius: 20px;
  background: rgba(0,255,163,.055);
  border: 1px solid rgba(0,255,163,.14);
}

.rindexBox strong {
  display: block;
  font-size: 22px;
  margin: 8px 0;
}

.rindexBox em {
  gap: 7px;
  font-style: normal;
  color: #cbd5e1;
  font-size: 13px;
}

.fineprint {
  margin-top: 14px;
  font-size: 13px;
  line-height: 1.6;
}

.bucket {
  display: grid;
  gap: 8px;
  margin-bottom: 14px;
}

.bucket div:first-child {
  display: flex;
  justify-content: space-between;
}

.bar {
  height: 9px;
  border-radius: 999px;
  overflow: hidden;
  background: rgba(255,255,255,.06);
}

.bar span {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: transparent !important;
}

.contractLink {
  gap: 10px;
  justify-content: space-between;
  padding: 13px 0;
  border-bottom: 1px solid rgba(255,255,255,.06);
}

.contractLink span { color: #cbd5e1; }

.trustGrid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
  margin-top: 16px;
}

.trustGrid span {
  padding: 12px;
  border-radius: 16px;
  color: #cbd5e1;
  background: rgba(255,255,255,.045);
}

.adminPanel { border-color: rgba(255,59,48,.25); }

.dangerPill {
  color: #fecaca;
  background: rgba(255,59,48,.12);
  border-color: rgba(255,59,48,.3);
}

.adminGrid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.adminGrid div {
  padding: 16px;
  border-radius: 18px;
  background: rgba(255,255,255,.04);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.adminGrid p {
  color: #94a3b8;
  line-height: 1.6;
  margin: 8px 0 14px;
}

.adminGrid button {
  color: #fff;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.08);
}

.overlay {
  position: fixed;
  inset: 0;
  z-index: 30;
  border: 0;
  background: rgba(0,0,0,.62);
  backdrop-filter: none !important;
}

.drawer {
  position: fixed;
  z-index: 31;
  top: 0;
  right: 0;
  width: min(390px, 92vw);
  min-height: 100vh;
  padding: 18px;
  animation: slideIn 150ms ease-out;
}

.drawerHead {
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 22px;
}

.drawerHead span {
  display: block;
  color: #94a3b8;
  margin-top: 5px;
  font-size: 13px;
}

.drawerNav {
  display: grid;
  gap: 8px;
}

.drawerNav a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 13px 14px;
  border-radius: 16px;
  color: #cbd5e1;
  background: rgba(255,255,255,.035);
  border: 1px solid rgba(255,255,255,.04);
}

.drawerSep {
  height: 1px;
  margin: 8px 0;
  background: rgba(255,255,255,.08);
}

.modalWrap {
  position: fixed;
  inset: 0;
  z-index: 40;
  display: grid;
  place-items: center;
  padding: 16px;
  background: rgba(0,0,0,.68);
  backdrop-filter: none !important;
}

.modal {
  width: min(480px, 100%);
  border-radius: 26px;
  padding: 20px;
}

.modalHead {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 18px;
}

.modalHead p {
  color: #94a3b8;
  margin-top: 5px;
  font-size: 14px;
}

.amountLabel {
  display: grid;
  gap: 8px;
  color: #cbd5e1;
  font-weight: 800;
}

.amountLabel input {
  width: 100%;
  height: 58px;
  border: 0;
  border-radius: 18px;
  padding: 0 16px;
  color: #fff;
  font-size: 26px;
  font-weight: 900;
  outline: none;
  background: rgba(255,255,255,.055);
  border: 1px solid rgba(255,255,255,.08);
}

.breakdown {
  display: grid;
  gap: 12px;
  padding: 16px;
  margin: 16px 0;
  border-radius: 20px;
  background: rgba(255,255,255,.035);
}

.breakdown div {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

@keyframes slideIn {
  from { transform: translateX(24px); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

@media (max-width: 760px) {
  /* network badge visible on mobile */
  .topbar { padding: 0 12px; }
  .brand span { display: none; }
  main { width: min(100% - 20px, 1180px); padding-top: 22px; }
  .panel, .heroCard { border-radius: 22px; padding: 16px; }
  .sectionHead { align-items: flex-start; }
}

@media (min-width: 900px) {
  .hero {
    grid-template-columns: 1fr 330px;
    align-items: end;
  }

  .grid {
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, .65fr);
  }

  .assetCard {
    grid-template-columns: 1.05fr 1.45fr auto;
    align-items: center;
  }

  .assetData {
    grid-template-columns: repeat(3, 1fr);
  }

  .assetData div {
    display: grid;
  }

  .assetActions {
    width: 190px;
  }
}

.viewHero {
  margin-bottom: 20px;
  padding: 28px 0 8px;
}

.viewHero h1 {
  max-width: 760px;
}

.viewHero p {
  margin-top: 14px;
  color: #94a3b8;
  max-width: 720px;
  line-height: 1.7;
}

.singlePanel {
  max-width: 760px;
}

.drawerNav button {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-align: left;
  padding: 13px 14px;
  border-radius: 16px;
  color: #cbd5e1;
  background: rgba(255,255,255,.035);
  border: 1px solid rgba(255,255,255,.04);
}

.drawerNav button.active {
  color: #00ffa3;
  border-color: rgba(0,255,163,.25);
  background: rgba(0,255,163,.07);
}

.drawerNav button:hover,
.drawerNav a:hover {
  color: #fff;
  border-color: rgba(0,255,163,.22);
}

.landingGrid {
  display: grid;
  gap: 16px;
  margin-top: 20px;
}

.landingCard {
  min-height: 210px;
  padding: 22px;
  border-radius: 26px;
  background: rgba(20,24,33,.62);
  border: 1px solid rgba(255,255,255,.075);
  box-shadow: none !important;
  backdrop-filter: none !important;
}

.primaryLanding {
  background: transparent !important;
  border-color: rgba(0,255,163,.18);
}

.wideLanding {
  min-height: unset;
}

.cardKicker {
  display: inline-flex;
  margin-bottom: 12px;
  color: #00ffa3;
  font-size: 12px;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.landingCard h2 {
  font-size: 24px;
  letter-spacing: -.04em;
  margin-bottom: 10px;
}

.landingCard p {
  color: #94a3b8;
  line-height: 1.7;
  margin-bottom: 18px;
}

.secondaryBtn {
  min-height: 42px;
  padding: 0 14px;
  border-radius: 14px;
  color: #fff;
  font-weight: 800;
  background: rgba(255,255,255,.065);
  border: 1px solid rgba(255,255,255,.08);
}

.miniStats {
  display: grid;
  gap: 10px;
}

.miniStats div {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  padding: 14px;
  border-radius: 18px;
  background: rgba(255,255,255,.045);
}

.miniStats span {
  color: #94a3b8;
}

.miniStats strong {
  font-family: "JetBrains Mono", "Roboto Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
}

@media (min-width: 840px) {
  .landingGrid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .primaryLanding {
    grid-column: span 2;
  }

  .wideLanding {
    grid-column: span 4;
  }

  .halfLanding {
    grid-column: span 2;
  }
}

.spin {
  animation: spin 900ms linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.miniBadge {
  display: inline-flex;
  margin-top: 8px;
  padding: 5px 8px;
  border-radius: 999px;
  font-style: normal;
  font-size: 11px;
  font-weight: 800;
  border: 1px solid rgba(255,255,255,.08);
}

.miniBadge.fresh {
  color: #86efac;
  background: rgba(0,255,163,.08);
  border-color: rgba(0,255,163,.16);
}

.miniBadge.stale {
  color: #fecaca;
  background: rgba(255,59,48,.1);
  border-color: rgba(255,59,48,.25);
}

.liveList {
  display: grid;
  gap: 10px;
  margin-top: 18px;
}

.liveList div {
  display: grid;
  gap: 5px;
  padding: 13px;
  border-radius: 16px;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.055);
}

.liveList strong {
  color: #fff;
}

.liveList span,
.liveList small {
  color: #94a3b8;
  font-size: 13px;
}

.liveList small {
  font-family: "JetBrains Mono", "Roboto Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
  line-height: 1.5;
}

.toast {
  position: fixed;
  right: 16px;
  bottom: 16px;
  z-index: 70;
  width: min(380px, calc(100% - 32px));
  display: grid;
  gap: 7px;
  padding: 15px;
  border-radius: 18px;
  background: rgba(20,24,33,.92);
  border: 1px solid rgba(255,255,255,.09);
  box-shadow: none !important;
  backdrop-filter: none !important;
}

.toast.success {
  border-color: rgba(0,255,163,.38);
}

.toast.info {
  border-color: rgba(0,225,255,.38);
}

.toast.error {
  border-color: rgba(255,59,48,.42);
}

.toast span {
  color: #cbd5e1;
  font-size: 14px;
  line-height: 1.45;
}

.toast a {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #00e1ff;
  font-size: 13px;
}


/* premium green UI polish */
:root {
  --forest-bg: #06140d;
  --forest-panel: rgba(8, 38, 27, .72);
  --forest-panel-strong: rgba(10, 54, 38, .82);
  --forest-line: rgba(103, 255, 199, .22);
  --forest-line-strong: rgba(103, 255, 199, .38);
  --forest-text: #ecfff8;
  --forest-muted: #9bc8bb;
  --forest-mint: #63ffc7;
  --forest-lime: #a7ff83;
  --forest-cyan: #4fe8ff;
}

body {
  background: transparent !important;
  color: var(--forest-text);
}

.app::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  opacity: .32;
  background: transparent !important;
  background-size: 58px 58px;
  mask-image: none !important;
}

main {
  position: relative;
  z-index: 1;
}

.glow {
  position: fixed;
  z-index: 0;
}

.topbar {
  z-index: 20;
}

.glowA {
  width: 340px;
  height: 340px;
  left: -120px;
  top: 70px;
  background: #63ffc7;
  opacity: .42;
}

.glowB {
  width: 420px;
  height: 420px;
  right: -150px;
  top: 180px;
  background: #27d17f;
  opacity: .34;
}

.topbar {
  height: 78px;
  background: rgba(5, 23, 15, .78);
  border-bottom: 1px solid var(--forest-line);
  box-shadow: none !important;
}

.brand {
  gap: 14px;
}

.brandIcon {
  width: 52px;
  height: 52px;
  padding: 4px;
  border-radius: 18px;
  overflow: hidden;
  background: transparent !important;
  border: 1px solid var(--forest-line-strong);
  box-shadow: none !important;
}

.brandIcon img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  border-radius: 14px;
}

.brand strong {
  letter-spacing: -.03em;
}

.brand span,
.hero p,
.sectionHead p,
.assetCard span,
.bucket span,
.breakdown span,
.rindexBox span,
.fineprint,
.drawerHead span,
.modalHead p,
.adminGrid p,
.landingCard p,
.miniStats span,
.liveList span,
.liveList small {
  color: var(--forest-muted);
}

main {
  width: min(1480px, calc(100% - 40px));
  padding-top: 42px;
}

.hero {
  position: relative;
  overflow: hidden;
  gap: 24px;
  min-height: 380px;
  padding: 28px;
  margin-bottom: 24px;
  border-radius: 34px;
  background: transparent !important;
  border: 1px solid var(--forest-line);
  box-shadow: none !important;
  backdrop-filter: none !important;
}

.hero::after {
  content: "";
  position: absolute;
  right: clamp(-40px, 2vw, 28px);
  top: 22px;
  width: clamp(220px, 24vw, 420px);
  height: clamp(220px, 24vw, 420px);
  background: url("/robin-vault-logo.jpg") center / cover no-repeat;
  border-radius: 50%;
  opacity: .10;
  filter: saturate(1.1) contrast(1.05);
  pointer-events: none;
}

.hero > * {
  position: relative;
  z-index: 1;
}

.eyebrow,
.cardKicker {
  color: var(--forest-mint);
}

h1 {
  max-width: 980px;
  text-shadow: 0 0 38px rgba(99,255,199,.10);
}

.heroCard,
.panel,
.modal,
.drawer,
.landingCard {
  background: transparent !important;
  border: 1px solid var(--forest-line);
  box-shadow: none !important;
}

.heroCard {
  min-height: 260px;
  display: grid;
  align-content: center;
  border-color: var(--forest-line-strong);
  background: transparent !important;
}

.heroCard strong,
.bigNumber,
.rindexBox strong,
.assetData strong,
.contractLink strong,
.breakdown strong,
.miniStats strong {
  color: var(--forest-text);
}

.primaryBtn,
.assetActions button:first-child {
  color: #04100b;
  background: transparent !important;
  box-shadow: none !important;
}

.secondaryBtn,
.assetActions button,
.adminGrid button,
.iconBtn,
.chainOk,
.chainBad,
.badges span,
.softPill,
.drawerNav button,
.drawerNav a {
  background: rgba(236,255,248,.065);
  border-color: rgba(103,255,199,.13);
}

.assetCard,
.adminGrid div,
.miniStats div,
.liveList div,
.breakdown,
.trustGrid span {
  background: rgba(236,255,248,.052);
  border: 1px solid rgba(103,255,199,.10);
}

.tokenMark {
  color: var(--forest-mint);
  background: rgba(99,255,199,.10);
  border-color: rgba(99,255,199,.22);
}

.rindexBox {
  background: transparent !important;
  border-color: rgba(99,255,199,.24);
}

.primaryLanding {
  position: relative;
  overflow: hidden;
  background: transparent !important;
  border-color: rgba(99,255,199,.30);
}

.primaryLanding::after {
  content: "";
  position: absolute;
  right: -34px;
  bottom: -54px;
  width: 230px;
  height: 230px;
  background: url("/robin-vault-logo.jpg") center / cover no-repeat;
  border-radius: 50%;
  opacity: .075;
  pointer-events: none;
}

.drawerNav button.active {
  color: var(--forest-mint);
  border-color: rgba(99,255,199,.34);
  background: rgba(99,255,199,.10);
}

.drawerNav button:hover,
.drawerNav a:hover {
  border-color: rgba(99,255,199,.30);
}

.bar span {
  background: transparent !important;
}

.toast {
  background: rgba(7, 31, 21, .94);
  border-color: rgba(103,255,199,.18);
}

@media (min-width: 900px) {
  .hero {
    grid-template-columns: minmax(0, 2fr) minmax(360px, .82fr);
    align-items: stretch;
  }

  .grid {
    grid-template-columns: minmax(0, 1.55fr) minmax(360px, .75fr);
  }

  .landingGrid {
    gap: 18px;
  }

  .landingCard {
    min-height: 240px;
  }

  .wideLanding {
    min-height: 190px;
  }
}

@media (min-width: 1280px) {
  .assetCard {
    grid-template-columns: 1.1fr 1.6fr 220px;
  }

  .assetActions {
    width: 220px;
  }
}

@media (max-width: 760px) {
  main {
    width: min(100% - 18px, 1180px);
    padding-top: 20px;
  }

  .topbar {
    height: 70px;
  }

  .brandIcon {
    width: 44px;
    height: 44px;
    border-radius: 15px;
  }

  .brandIcon img {
    border-radius: 11px;
  }

  .hero {
    min-height: unset;
    padding: 20px;
    border-radius: 26px;
  }

  .hero::after {
    width: 210px;
    height: 210px;
    right: -74px;
    top: 34px;
    opacity: .075;
  }

  .heroCard {
    min-height: unset;
  }
}

@media (prefers-reduced-motion: reduce) {
  * {
    animation: none !important;
    transition: none !important;
    scroll-behavior: auto !important;
  }
}


/* topbar and public trust layout refinement */
.brandBlank {
  width: 44px;
  min-width: 44px;
  height: 44px;
}

.topbar {
  justify-content: flex-end;
}

.topActions {
  margin-left: auto;
}

.trustWide {
  min-height: 178px;
  position: relative;
  overflow: hidden;
  border-color: rgba(103,255,199,.28);
  background: transparent !important;
}

.trustWide::after {
  content: "";
  position: absolute;
  right: 26px;
  bottom: -72px;
  width: 230px;
  height: 230px;
  background: url("/robin-vault-logo.jpg") center / cover no-repeat;
  border-radius: 50%;
  opacity: .055;
  pointer-events: none;
}

.trustWide > * {
  position: relative;
  z-index: 1;
}

@media (min-width: 840px) {
  .trustWide {
    grid-column: span 4;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 20px;
  }

  .trustWide p {
    max-width: 820px;
    margin-bottom: 0;
  }

  .trustWide .secondaryBtn {
    align-self: end;
    min-width: 170px;
  }
}

@media (max-width: 760px) {
  .topbar {
    justify-content: flex-end;
  }

  .brandBlank {
    display: none;
  }

  .trustWide {
    min-height: unset;
  }

  .trustWide::after {
    width: 180px;
    height: 180px;
    right: -42px;
    bottom: -64px;
  }
}


/* trust wide hard fix */
.trustWide {
  width: 100%;
  min-height: 168px;
}

@media (min-width: 840px) {
  .landingGrid .trustWide {
    grid-column: 1 / -1 !important;
  }
}


/* front page final polish */
.assetStrip {
  min-height: 150px;
  display: grid;
  gap: 18px;
  align-items: center;
  border-color: rgba(103,255,199,.24);
  background: transparent !important;
}

.assetStrip p {
  max-width: 860px;
  margin-bottom: 0;
}

.assetChips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.assetChips span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38px;
  padding: 0 13px;
  border-radius: 999px;
  color: #06140d;
  font-weight: 900;
  letter-spacing: .03em;
  background: transparent !important;
  box-shadow: none !important;
}

@media (min-width: 840px) {
  .landingGrid .assetStrip {
    grid-column: 1 / -1;
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .assetChips {
    justify-content: flex-end;
    min-width: 360px;
  }
}

@media (max-width: 760px) {
  .trustWide .secondaryBtn,
  .assetStrip .secondaryBtn {
    width: 100%;
  }

  .trustWide {
    display: grid;
    gap: 16px;
  }

  .trustWide .secondaryBtn {
    justify-self: stretch;
  }

  .assetChips span {
    flex: 1;
    min-width: 72px;
  }
}


/* vault ledger UX polish */
.ledgerNotice {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  margin: -4px 0 16px;
  padding: 13px 15px;
  border-radius: 18px;
  background: transparent !important;
  border: 1px solid rgba(103,255,199,.13);
}

.ledgerNotice strong {
  color: var(--forest-text);
}

.ledgerNotice span {
  color: var(--forest-muted);
  line-height: 1.45;
  font-size: 14px;
}

.assetActions button:disabled {
  color: rgba(236,255,248,.46);
  background: rgba(236,255,248,.045);
  border-color: rgba(236,255,248,.055);
  box-shadow: none !important;
}

@media (max-width: 760px) {
  .ledgerNotice {
    display: grid;
    gap: 6px;
  }

  .assetActions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
  }
}

/* mobile vault density polish */
@media (max-width: 760px) {
  .viewHero {
    padding: 18px 0 14px;
    margin-bottom: 12px;
  }

  .viewHero h1 {
    font-size: clamp(38px, 11vw, 50px);
    line-height: .96;
  }

  .viewHero p {
    margin-top: 10px;
    font-size: 15px;
    line-height: 1.55;
  }

  #ledger.panel {
    padding: 14px;
    border-radius: 24px;
  }

  #ledger .sectionHead {
    margin-bottom: 12px;
  }

  #ledger .sectionHead h2 {
    font-size: 22px;
  }

  #ledger .sectionHead p {
    font-size: 14px;
  }

  #ledger .secondaryBtn {
    min-height: 44px;
    padding: 0 16px;
    border-radius: 16px;
  }

  .assetList {
    gap: 10px;
  }

  .assetCard {
    padding: 14px;
    gap: 12px;
    border-radius: 22px;
  }

  .assetMain {
    gap: 12px;
  }

  .tokenMark {
    width: 52px;
    height: 52px;
    border-radius: 18px;
    font-size: 20px;
  }

  .assetMain strong {
    font-size: 21px;
  }

  .assetMain span {
    font-size: 14px;
  }

  .miniBadge {
    margin-top: 7px;
    font-size: 11px;
    padding: 5px 9px;
  }

  .assetData {
    gap: 7px;
  }

  .assetData div {
    align-items: center;
  }

  .assetData span {
    font-size: 15px;
  }

  .assetData strong {
    font-size: 18px;
    text-align: right;
  }

  .assetActions {
    gap: 10px;
  }

  .assetActions button {
    min-height: 52px;
    border-radius: 18px;
    font-size: 18px;
  }
}

/* supported asset chip mobile balance */
@media (max-width: 760px) {
  .assetChips {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .assetChips span {
    width: 100%;
    min-width: 0;
    flex: unset;
  }

  .assetChips span:nth-child(4) {
    grid-column: 1 / 2;
  }

  .assetChips span:nth-child(5) {
    grid-column: 2 / 4;
  }
}

/* remove repeated dashboard logo watermarks */
.primaryLanding::after,
.trustWide::after {
  display: none !important;
}

/* drawer size polish */
@media (max-width: 760px) {
  .drawer {
    width: min(350px, 86vw);
    padding: 14px;
  }

  .drawerHead {
    margin-bottom: 16px;
  }

  .drawerHead h3 {
    font-size: 20px;
  }

  .drawerHead span {
    font-size: 13px;
  }

  .drawer .iconBtn {
    width: 48px;
    height: 48px;
    border-radius: 18px;
  }

  .drawerNav {
    gap: 8px;
  }

  .drawerNav button,
  .drawerNav a {
    min-height: 52px;
    padding: 0 13px;
    border-radius: 15px;
    font-size: 16px;
  }

  .drawerSep {
    margin: 12px 0;
  }
}

@media (max-width: 420px) {
  .drawer {
    width: min(330px, 84vw);
  }

  .drawerNav button,
  .drawerNav a {
    min-height: 50px;
    font-size: 15px;
  }
}

/* desktop drawer width restore */
@media (min-width: 761px) {
  .drawer {
    width: min(420px, 34vw);
  }
}

/* desktop modal polish */
@media (min-width: 900px) {
  .modal {
    width: min(600px, 100%);
    padding: 26px;
    border-radius: 30px;
  }

  .modalHead h3 {
    font-size: 24px;
  }

  .modalHead p {
    font-size: 15px;
  }

  .amountLabel {
    font-size: 16px;
  }

  .amountLabel input {
    height: 66px;
    font-size: 32px;
    border-radius: 20px;
  }

  .breakdown {
    padding: 20px;
    border-radius: 22px;
  }

  .breakdown div {
    font-size: 16px;
  }

  .primaryBtn.wide {
    min-height: 54px;
    font-size: 16px;
  }

  .modal .fineprint {
    font-size: 14px;
  }
}

/* modal CTA weight polish */
.primaryBtn.wide {
  font-weight: 900;
}


/* mobile network badge polish */
@media (max-width: 760px) {
  .chainOk,
  .chainBad {
    display: inline-flex;
    min-height: 34px;
    padding: 0 10px;
    gap: 6px;
    font-size: 11px;
    white-space: nowrap;
  }

  .chainOk span,
  .chainBad span {
    width: 7px;
    height: 7px;
  }

  .topActions {
    gap: 7px;
  }
}

@media (max-width: 390px) {
  .chainOk,
  .chainBad {
    max-width: 118px;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 0 8px;
    font-size: 10px;
  }
}


/* rINDEX panel polish */
.rindexPanel {
  max-width: 900px;
  overflow: hidden;
  background: transparent !important;
}

.rindexHeroMetric {
  display: grid;
  gap: 8px;
  margin-bottom: 18px;
}

.rindexHeroMetric > span {
  color: var(--forest-muted);
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: .08em;
}

.rindexHeroMetric .bigNumber {
  margin-bottom: 0;
}

.rindexHeroMetric p {
  color: var(--forest-muted);
  line-height: 1.55;
  margin: 0;
}

.rindexReceiptBox {
  margin-bottom: 14px;
  background: transparent !important;
}

.receiptInfoGrid {
  display: grid;
  gap: 10px;
  margin: 14px 0;
}

.receiptInfoGrid div {
  display: grid;
  gap: 6px;
  padding: 14px;
  border-radius: 18px;
  background: rgba(236,255,248,.052);
  border: 1px solid rgba(103,255,199,.11);
}

.receiptInfoGrid span {
  color: var(--forest-muted);
  font-size: 13px;
}

.receiptInfoGrid strong {
  color: var(--forest-text);
  font-family: "JetBrains Mono", "Roboto Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
}

@media (min-width: 760px) {
  .receiptInfoGrid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 760px) {
  .rindexPanel {
    max-width: none;
  }

  .rindexHeroMetric > span {
    font-size: 12px;
  }

  .receiptInfoGrid {
    grid-template-columns: 1fr;
  }
}

/* rINDEX desktop width polish */
@media (min-width: 900px) {
  .rindexPanel {
    max-width: 1080px;
  }
}

/* mobile rINDEX centering polish */
@media (max-width: 760px) {
  .rindexPanel {
    width: calc(100% - 8px);
    margin-left: auto;
    margin-right: auto;
  }

  .rindexReceiptBox,
  .receiptInfoGrid div {
    margin-left: auto;
    margin-right: auto;
    width: 100%;
  }
}

/* desktop hero watermark + rINDEX alignment polish */
@media (min-width: 900px) {
  /* move hero watermark away from the network card */
  .hero::after {
    right: 430px;
    top: 56px;
    width: 300px;
    height: 300px;
    opacity: .055;
  }

  /* center and widen rINDEX page only */
  .singlePanel:has(.rindexPanel) {
    width: min(1120px, 100%);
    max-width: 1120px;
    margin-left: auto;
    margin-right: auto;
  }

  .rindexPanel {
    width: 100%;
    max-width: none;
  }
}

@media (min-width: 1280px) {
  .hero::after {
    right: 460px;
    width: 340px;
    height: 340px;
  }

  .singlePanel:has(.rindexPanel) {
    width: min(1180px, 100%);
    max-width: 1180px;
  }
}

/* desktop hero logo anchor polish */
@media (min-width: 900px) {
  .hero::after {
    left: 36px;
    top: 36px;
    right: auto;
    bottom: auto;
    width: 280px;
    height: 280px;
    opacity: .045;
  }
}

@media (min-width: 1280px) {
  .hero::after {
    left: 42px;
    top: 42px;
    width: 320px;
    height: 320px;
    opacity: .045;
  }
}

/* move hero logo watermark into Network Status card */
.hero::after {
  display: none !important;
}

.heroCard {
  position: relative;
  overflow: hidden;
}

.heroCard::after {
  content: "";
  position: absolute;
  right: 18px;
  top: 50%;
  width: 190px;
  height: 190px;
  transform: translateY(-50%);
  background: url("/robin-vault-logo.jpg") center / cover no-repeat;
  border-radius: 50%;
  opacity: .075;
  pointer-events: none;
  filter: saturate(1.08) contrast(1.05);
}

.heroCard > * {
  position: relative;
  z-index: 1;
}

@media (min-width: 1280px) {
  .heroCard::after {
    right: 22px;
    width: 220px;
    height: 220px;
    opacity: .07;
  }
}

@media (max-width: 760px) {
  .heroCard::after {
    right: -28px;
    width: 180px;
    height: 180px;
    opacity: .065;
  }
}

/* desktop network logo + treasury polish */
@media (min-width: 900px) {
  .heroCard::after {
    right: -18px;
    top: 50%;
    width: 300px;
    height: 300px;
    opacity: .075;
  }
}

@media (min-width: 1280px) {
  .heroCard::after {
    right: -28px;
    width: 340px;
    height: 340px;
    opacity: .07;
  }
}

.treasuryPanel {
  max-width: 1080px;
  overflow: hidden;
  background: transparent !important;
}

.treasurySplitGrid {
  display: grid;
  gap: 10px;
  margin-bottom: 18px;
}

.treasurySplitGrid div {
  display: grid;
  gap: 5px;
  padding: 14px;
  border-radius: 18px;
  background: rgba(236,255,248,.052);
  border: 1px solid rgba(103,255,199,.11);
}

.treasurySplitGrid span,
.treasurySplitGrid em,
.treasuryTokenTop span,
.treasuryMetricRows span,
.treasuryBucketMini span {
  color: var(--forest-muted);
}

.treasurySplitGrid strong {
  color: var(--forest-text);
  font-size: 24px;
  font-family: "JetBrains Mono", "Roboto Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
}

.treasurySplitGrid em {
  font-style: normal;
  font-size: 13px;
}

.bucketBars {
  display: grid;
  gap: 12px;
  margin-bottom: 22px;
}

.treasuryTokenHead {
  margin-top: 8px;
}

.treasuryTokenGrid {
  display: grid;
  gap: 12px;
}

.treasuryTokenCard {
  display: grid;
  gap: 14px;
  padding: 16px;
  border-radius: 20px;
  background: transparent !important;
  border: 1px solid rgba(103,255,199,.11);
}

.treasuryTokenTop {
  display: grid;
  gap: 3px;
}

.treasuryTokenTop strong {
  color: var(--forest-text);
  font-size: 22px;
}

.treasuryTokenTop span {
  font-size: 13px;
}

.treasuryMetricRows {
  display: grid;
  gap: 8px;
}

.treasuryMetricRows div,
.treasuryBucketMini div {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.treasuryMetricRows strong,
.treasuryBucketMini strong {
  color: var(--forest-text);
  font-family: "JetBrains Mono", "Roboto Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
  text-align: right;
}

.treasuryBucketMini {
  display: grid;
  gap: 7px;
  padding-top: 12px;
  border-top: 1px solid rgba(103,255,199,.10);
}

@media (min-width: 760px) {
  .treasurySplitGrid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .treasuryTokenGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (min-width: 1180px) {
  .treasuryTokenGrid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (max-width: 760px) {
  .treasuryPanel {
    max-width: none;
  }

  .treasurySplitGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .treasurySplitGrid strong {
    font-size: 22px;
  }

  .treasuryTokenGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .treasuryTokenCard {
    padding: 12px;
    gap: 10px;
  }

  .treasuryOperatorRow button {
    font-size: 11px;
    min-height: 32px;
    padding: 0 10px;
  }

  .treasuryOperatorRow span {
    font-size: 10px;
  }

  .treasuryMetricRows div,
  .treasuryBucketMini div {
    align-items: center;
  }
}

/* treasury desktop full-width polish */
@media (min-width: 900px) {
  .singlePanel:has(.treasuryPanel) {
    width: min(1380px, 100%);
    max-width: 1380px;
    margin-left: auto;
    margin-right: auto;
  }

  .treasuryPanel {
    width: 100%;
    max-width: none;
  }

  .treasuryTokenGrid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (min-width: 1280px) {
  .singlePanel:has(.treasuryPanel) {
    width: min(1480px, 100%);
    max-width: 1480px;
  }
}

/* verified contracts alignment polish */
.contractsPanel {
  max-width: 1080px;
}

.contractsPanel .contractLink {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 170px 24px;
  align-items: center;
  gap: 14px;
}

.contractsPanel .contractLink span {
  min-width: 0;
}

.contractsPanel .contractLink strong {
  justify-self: end;
  width: 170px;
  text-align: right;
  font-variant-numeric: tabular-nums;
  letter-spacing: .02em;
}

.contractsPanel .contractLink svg {
  justify-self: end;
}

@media (min-width: 900px) {
  .singlePanel:has(.contractsPanel) {
    width: min(1180px, 100%);
    max-width: 1180px;
    margin-left: auto;
    margin-right: auto;
  }

  .contractsPanel {
    width: 100%;
    max-width: none;
  }
}

@media (max-width: 760px) {
  .contractsPanel .contractLink {
    grid-template-columns: minmax(0, 1fr) 155px 22px;
    gap: 10px;
  }

  .contractsPanel .contractLink strong {
    width: 155px;
    font-size: 15px;
  }

  .contractsPanel .trustGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 390px) {
  .contractsPanel .contractLink {
    grid-template-columns: 1fr;
    gap: 6px;
  }

  .contractsPanel .contractLink strong {
    justify-self: start;
    width: auto;
    text-align: left;
  }

  .contractsPanel .contractLink svg {
    position: absolute;
    right: 0;
  }
}

/* local polish: read failure notice */
.ledgerNotice.readIssue {
  border-color: rgba(255, 202, 87, .28);
  background: transparent !important;
}

.ledgerNotice.readIssue strong {
  color: #ffe7a3;
}

/* local polish: manual contract preview button */
.secondaryBtn.previewBtn {
  width: 100%;
  margin-top: 8px;
  justify-content: center;
}

/* contract preview button intentionally disabled for mobile stability */

/* local polish: admin read-only control room */
.adminSummaryGrid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-bottom: 18px;
}

.adminSummaryGrid > div,
.adminTokenCard {
  border: 1px solid rgba(132, 255, 178, .14);
  background: rgba(8, 44, 29, .58);
  border-radius: 22px;
  padding: 16px;
  box-shadow: none !important;
}

.adminSummaryGrid span,
.adminTokenCard span,
.adminMetricRows span,
.adminBucketMini span {
  color: rgba(226, 255, 237, .68);
}

.adminSummaryGrid strong {
  display: block;
  margin-top: 8px;
  font-size: clamp(18px, 2vw, 26px);
}

.adminSummaryGrid em {
  display: block;
  margin-top: 6px;
  color: rgba(226, 255, 237, .55);
  font-style: normal;
  font-size: 13px;
}

.adminTokenGrid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
  margin: 18px 0;
}

.adminTokenCard > div:first-child {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 14px;
}

.adminTokenCard > div:first-child strong {
  font-size: 20px;
}

.adminMetricRows {
  display: grid;
  gap: 10px;
}

.adminMetricRows > div {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  border-top: 1px solid rgba(132, 255, 178, .10);
  padding-top: 10px;
}

.adminBucketMini {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
  margin-top: 14px;
  font-size: 12px;
}

.adminTokenCard button {
  width: 100%;
  margin-top: 14px;
}

@media (max-width: 760px) {
  .adminSummaryGrid,
  .adminTokenGrid {
    grid-template-columns: 1fr;
  }

  .adminMetricRows > div {
    align-items: flex-start;
    flex-direction: column;
  }
}

/* local polish: clearer disabled admin buttons */
.adminPanel button:disabled,
.adminTokenCard button:disabled {
  opacity: 1;
  color: rgba(226, 255, 237, .58);
  background: rgba(226, 255, 237, .075);
  border: 1px solid rgba(226, 255, 237, .08);
  cursor: not-allowed;
}

.adminTokenCard button:disabled {
  font-weight: 700;
  letter-spacing: .01em;
}

/* local polish: enabled admin sweep controls */
.adminTokenCard button:not(:disabled) {
  color: #04160f;
  background: transparent !important;
  border: 1px solid rgba(132, 255, 178, .35);
  box-shadow: none !important;
  cursor: pointer;
}

.adminTokenCard button:not(:disabled):active {
  transform: translateY(1px);
}

/* Reward Panel v2 */
.rewardPanelClean {
  width: 100%;
  max-width: 100%;
  margin-top: 20px;
  padding: 16px;
  overflow: hidden;
  border: 1px solid rgba(135, 255, 181, 0.16);
  border-radius: 20px;
  background: transparent !important;
}

.rewardPanelClean *,
.rewardPanelClean *::before,
.rewardPanelClean *::after {
  box-sizing: border-box;
  transition: none !important;
  animation: none !important;
}

.rewardPanelHead {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
  margin-bottom: 14px;
}

.rewardPanelHead h2 {
  margin: 0 0 5px;
  color: #f2fff7;
  font-size: clamp(22px, 3vw, 30px);
  line-height: 1;
  letter-spacing: -0.035em;
}

.rewardEyebrow {
  margin: 0 0 6px;
  color: #7dffb3;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.13em;
  text-transform: uppercase;
}

.rewardMuted {
  margin: 0;
  max-width: 760px;
  color: rgba(230, 255, 239, 0.68);
  font-size: 12px;
  line-height: 1.45;
}

.rewardRefreshButton,
.rewardClaimButton {
  border: 0;
  border-radius: 999px;
  font-weight: 900;
  cursor: pointer;
}

.rewardRefreshButton {
  flex: 0 0 auto;
  padding: 8px 12px;
  background: rgba(145, 255, 188, 0.13);
  color: #edfff3;
  border: 1px solid rgba(145, 255, 188, 0.15);
}

.rewardSummaryGrid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 9px;
  margin-bottom: 12px;
}

.rewardSummaryCard {
  min-width: 0;
  padding: 10px 11px;
  border: 1px solid rgba(145, 255, 188, 0.10);
  border-radius: 13px;
  background: rgba(0, 20, 12, 0.24);
}

.rewardSummaryCard span {
  display: block;
  margin-bottom: 5px;
  color: rgba(230, 255, 239, 0.56);
  font-size: 10px;
}

.rewardSummaryCard strong {
  color: #f2fff7;
  font-size: 12px;
  word-break: break-word;
}

.rewardAssetGrid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10px;
}

.rewardAssetCard {
  min-width: 0;
  padding: 12px;
  border: 1px solid rgba(135, 255, 181, 0.14);
  border-radius: 18px;
  background: transparent !important;
  box-shadow: none !important;
}

.rewardAssetTop {
  display: grid;
  grid-template-columns: 1fr;
  gap: 7px;
  margin-bottom: 10px;
}

.rewardSymbol {
  display: block;
  color: #f2fff7;
  font-size: 18px;
  line-height: 1;
}

.rewardSubtext {
  display: block;
  margin-top: 4px;
  color: rgba(230, 255, 239, 0.52);
  font-size: 10px;
}

.rewardBadgeRow {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
}

.rewardBadge {
  display: inline-flex;
  align-items: center;
  padding: 3px 6px;
  border-radius: 999px;
  background: rgba(148, 163, 184, 0.13);
  color: rgba(230, 255, 239, 0.78);
  font-size: 9px;
  font-weight: 800;
  white-space: nowrap;
}

.rewardBadgeOk {
  background: rgba(74, 222, 128, 0.15);
  color: #a7ffbf;
}

.rewardBadgeInfo {
  background: rgba(45, 212, 191, 0.13);
  color: #a7fff3;
}

.rewardMetricGrid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 6px;
}

.rewardMetric {
  min-width: 0;
  padding: 8px;
  border-radius: 10px;
  background: rgba(2, 33, 21, 0.38);
  border: 1px solid rgba(135, 255, 181, 0.075);
}

.rewardMetric span,
.rewardClaimRow span {
  display: block;
  margin-bottom: 3px;
  color: rgba(230, 255, 239, 0.50);
  font-size: 9px;
}

.rewardMetric strong,
.rewardClaimRow strong {
  display: block;
  color: #f2fff7;
  font-size: 11px;
  word-break: break-word;
}

.rewardClaimRow {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 8px;
  margin-top: 9px;
  padding-top: 9px;
  border-top: 1px solid rgba(145, 255, 188, 0.08);
}

.rewardClaimButton {
  min-width: 72px;
  padding: 8px 11px;
  background: transparent !important;
  color: #032215;
  font-size: 11px;
}

.rewardClaimButton:disabled {
  cursor: not-allowed;
  opacity: 0.42;
}

.rewardLoading {
  padding: 14px;
  border-radius: 13px;
  background: rgba(0, 20, 12, 0.24);
  color: rgba(230, 255, 239, 0.70);
}

.rewardSuccess,
.rewardError {
  margin: 12px 0 0;
  font-weight: 900;
}

.rewardSuccess {
  color: #a7ffbf;
}

.rewardError {
  color: #fca5a5;
}

@media (max-width: 900px) {
  .rewardAssetGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 680px) {
  .rewardPanelClean {
  width: 100%;
  max-width: 100%;
  margin-top: 20px;
  padding: 16px;
  overflow: hidden;
  border: 1px solid rgba(135, 255, 181, 0.16);
  border-radius: 20px;
  background: transparent !important;
}

  .rewardPanelHead {
    display: block;
  }

  .rewardRefreshButton {
    width: 100%;
    margin-top: 10px;
  }

  .rewardSummaryGrid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px;
  }

  .rewardAssetGrid {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .rewardAssetCard {
  min-width: 0;
  padding: 12px;
  border: 1px solid rgba(135, 255, 181, 0.14);
  border-radius: 18px;
  background: transparent !important;
  box-shadow: none !important;
}

  .rewardMetricGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .rewardClaimRow {
    grid-template-columns: 1fr auto;
  }

  .rewardClaimButton {
    min-width: 82px;
  }
}

@media (max-width: 390px) {
  .rewardMetricGrid {
    grid-template-columns: 1fr;
  }

  .rewardClaimRow {
    grid-template-columns: 1fr;
  }

  .rewardClaimButton {
    width: 100%;
  }
}
/* End Reward Panel v2 */

/* Reward Panel color polish: match Treasury token bucket cards */
.rewardPanelClean {
  background: transparent !important;
}

.rewardAssetCard {
  background: transparent !important;
  border-color: rgba(135, 255, 181, 0.13) !important;
  box-shadow: none !important;
}

.rewardMetric {
  background: rgba(1, 31, 20, 0.34) !important;
  border-color: rgba(135, 255, 181, 0.055) !important;
}

.rewardSummaryCard {
  background: rgba(1, 31, 20, 0.30) !important;
  border-color: rgba(135, 255, 181, 0.10) !important;
}

.rewardBadgeOk {
  background: rgba(74, 222, 128, 0.13) !important;
}

.rewardBadgeInfo {
  background: rgba(45, 212, 191, 0.105) !important;
}

.rewardClaimButton {
  background: transparent !important;
}

/* v0.4.0 reward status visual alignment */
.rewardPanelClean {
  background: transparent !important;
  border-color: rgba(130, 255, 180, 0.18);
}

.rewardSummaryCard,
.rewardAssetCard,
.rewardMetric {
  background: transparent !important;
  border: 1px solid rgba(130, 255, 180, 0.14);
  box-shadow: none !important;
}

.rewardAssetCard {
  border-radius: 18px;
}

.rewardMetric {
  border-radius: 12px;
}

.rewardBadgeOk,
.rewardBadgeInfo {
  background: rgba(120, 255, 170, 0.12);
  border: 1px solid rgba(120, 255, 170, 0.18);
}

@media (min-width: 900px) {
  .rewardSummaryGrid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .rewardAssetGrid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .rewardAssetCard {
    padding: 14px;
    min-height: auto;
  }

  .rewardAssetTop {
    margin-bottom: 8px;
  }

  .rewardSymbol {
    font-size: 20px;
    line-height: 1;
  }

  .rewardSubtext {
    font-size: 12px;
  }

  .rewardBadgeRow {
    gap: 6px;
    margin-top: 8px;
  }

  .rewardBadge {
    padding: 4px 7px;
    font-size: 10px;
  }

  .rewardMetricGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 7px;
    margin-top: 10px;
  }

  .rewardMetric {
    padding: 8px;
  }

  .rewardMetric span,
  .rewardClaimRow span {
    font-size: 10px;
  }

  .rewardMetric strong,
  .rewardClaimRow strong {
    font-size: 12px;
  }

  .rewardClaimRow {
    padding: 8px;
    margin-top: 8px;
  }

  .rewardClaimButton {
    min-height: 34px;
    margin-top: 8px;
  }
}

@media (max-width: 899px) {
  .rewardSummaryCard,
  .rewardAssetCard,
  .rewardMetric {
    background: transparent !important;
  }
}


/* v0.6.0 — compact reward metric grid (old, replaced) */
@media (min-width: 900px) {
  .rewardMetricGrid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 5px;
    margin-top: 8px;
  }
  .rewardMetric {
    padding: 6px 7px;
  }
  .rewardMetric span {
    font-size: 9px;
    margin-bottom: 2px;
  }
  .rewardMetric strong {
    font-size: 10px;
  }
}

@media (max-width: 899px) {
  .rewardMetricGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 5px;
  }
}


